{
    "configurations": [
        {
    "name": "windows-gcc-x64",
    "includePath": [
        // 项目根目录（递归搜索所有子文件夹）
        "${workspaceFolder}/**",
        // 核心头文件目录
        "${workspaceFolder}/Core/Inc",
        "${workspaceFolder}/Drivers/CMSIS/Core/Include",
        "${workspaceFolder}/Drivers/CMSIS/Device/ST/STM32H7xx/Include",
        "${workspaceFolder}/Drivers/STM32H7xx_HAL_Driver/Inc",
        "${workspaceFolder}/Algorithm/Include",
        "${workspaceFolder}/Algorithm",
        // STM32H7xx specific paths
        "${workspaceFolder}/Drivers/STM32H7xx_HAL_Driver/Inc/Legacy"
    ],
    "compilerPath": "C:/msys64/ucrt64/bin/gcc.exe",
    "intelliSenseMode": "windows-gcc-x64",
    "compilerArgs": [
        "-DSTM32H723xx",
        "-DUSE_HAL_DRIVER",
        "-DUSE_HAL_DRIVER",
        "-DCORE_CM7"
    ],
    "mergeConfigurations": false,
    "browse": {
        "path": [
            // 同步更新 browse 路径（保持和 includePath 一致）
            "${workspaceFolder}/**",
            "${workspaceFolder}/Core/Inc",
            "${workspaceFolder}/Drivers/CMSIS/Core/Include",
            "${workspaceFolder}/Drivers/CMSIS/Device/ST/STM32H7xx/Include",
            "${workspaceFolder}/Drivers/STM32H7xx_HAL_Driver/Inc",
            "${workspaceFolder}/Algorithm/Include",
            "${workspaceFolder}/Algorithm",
            // STM32H7xx specific paths
            "${workspaceFolder}/Drivers/STM32H7xx_HAL_Driver/Inc/Legacy"
        ],
        "limitSymbolsToIncludedHeaders": true
    },
    "cStandard": "c17"
        },
        {
            "name": "arm-gnu-toolchain",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/User/Hardware",
                "${workspaceFolder}/User/BSP",
                "${workspaceFolder}/User/Software"
            ],
            "defines": [
                "USE_HAL_DRIVER",
                "STM32H723xx",
                "YOUNG_OMNI",
                "CORE_CM7"
            ],
            "compilerPath": "C:\\msys64\\ucrt64\\bin\\gcc.exe",
            "cStandard": "c17",
            "cppStandard": "gnu++14",
            "intelliSenseMode": "gcc-arm"
        }
    ],
    "version": 4
}